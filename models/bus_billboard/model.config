<?xml version="1.0"?>
<!-- 上一行声明这是一个 XML 文件，XML 声明必须放在文件第一行。 -->
<!-- 打开 model 标签，描述一个可被 Gazebo 加载的模型。 -->
<model>
  <!-- 设置模型名称，Gazebo 会用它识别这个图片平面模型。 -->
  <name>bus_billboard</name>
  <!-- 设置模型版本号，方便以后修改模型时区分版本。 -->
  <version>1.0</version>
  <!-- 指定这个模型使用的 SDF 文件。 -->
  <sdf version="1.6">model.sdf</sdf>
  <!-- 填写模型作者信息，这里使用课程名称作为占位作者。 -->
  <author>
    <!-- 设置作者名称。 -->
    <name>YOLO Course</name>
  <!-- 结束作者信息。 -->
  </author>
  <!-- 添加模型说明，方便以后知道这个模型的用途。 -->
  <description>Textured bus image billboard for YOLO Gazebo validation.</description>
<!-- 结束 model 标签。 -->
</model>
